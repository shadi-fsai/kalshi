# Kalshi production API credentials.
# Generate these at https://kalshi.com/account/profile (API Keys section).
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
#
# NOTE: Placing/canceling orders and reading your portfolio require an API key
# with trading + portfolio scopes (not a read-only key). Browsing markets and
# sizing bets works with any key.

# The Key ID shown when you created the API key.
KALSHI_API_KEY_ID=

# Path to the downloaded RSA private key file (PEM/.key). Recommended.
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.key

# Alternatively, paste the PEM contents inline instead of using a file path.
# If both are set, KALSHI_PRIVATE_KEY_PATH takes precedence.
# KALSHI_PRIVATE_KEY=

# Optional: override the REST base URL (defaults to production).
# Production: https://external-api.kalshi.com/trade-api/v2
# Demo:       https://external-api.demo.kalshi.co/trade-api/v2
# KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2

# Optional: where the stop-loss manager/engine keep their config + status files
# (defaults to ./.kalshi_stops). Both the Portfolio page and kalshi-stop-engine
# must point at the same directory.
# KALSHI_STOPS_DIR=./.kalshi_stops

# Optional: override the WebSocket URL used by the stop tools (defaults to the
# host derived from KALSHI_API_BASE).
# KALSHI_WS_URL=
